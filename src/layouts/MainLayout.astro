---
import Header from "../components/Header.astro";
import "../styles/global.css";
import { BASE_API_URL } from "../api/constants";
interface Props {
  isHomePage?: boolean;
}
const { isHomePage = false } = Astro.props;

const whatsappNumber = import.meta.env.PUBLIC_WHATSAPP_PHONE || "905306544317";
const whatsappMessage = encodeURIComponent("Merhaba, bilgi almak istiyorum.");
const whatsappUrl = `https://wa.me/${whatsappNumber}?text=${whatsappMessage}`;
---

<!DOCTYPE html>
<html lang="tr">
  <head>
    <script is:inline>
      (function () {
        var t = localStorage.getItem("theme");
        if (t === "dark" || (!t && window.matchMedia("(prefers-color-scheme: dark)").matches))
          document.documentElement.classList.add("dark");
        else document.documentElement.classList.remove("dark");
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&family=Montserrat:ital,wght@0,100..900;1,100..900&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap" rel="stylesheet">
    <title>Site</title>
  </head>
  <body class="min-h-screen bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100 transition-colors duration-200">
    <Header isHomePage={isHomePage} />
    <main class="w-full bg-gray-50 dark:bg-gray-900 transition-colors duration-200">
      <slot />
    </main>

    <!-- Teklif Formu Modal (tüm sayfalarda; header "Teklif Al" ve bina yönetimi butonu ile açılır) -->
    <div
      id="teklif-form-modal"
      class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/50 dark:bg-black/70 p-4"
      role="dialog"
      aria-modal="true"
      aria-labelledby="teklif-form-title"
      aria-hidden="true"
    >
      <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-xl w-full max-w-xl max-h-[90vh] overflow-y-auto text-gray-900 dark:text-gray-100">
        <div class="relative p-6 sm:p-8">
          <button
            type="button"
            id="teklif-form-close"
            class="absolute top-4 right-4 w-9 h-9 rounded-lg bg-[#404040] text-white hover:bg-[#525252] flex items-center justify-center transition-colors"
            aria-label="Kapat"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>

          <h2 id="teklif-form-title" class="text-center text-[#262322] dark:text-gray-100 font-bold mb-6 sm:mb-8 text-xl sm:text-2xl">
            Hemen Teklif Al
          </h2>

          <form id="teklif-form" class="space-y-4 sm:space-y-5">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-5">
              <div>
                <label for="teklif-ad-soyad" class="block text-[#262322] dark:text-gray-200 text-sm font-medium mb-1.5">Ad Soyad</label>
                <input
                  type="text"
                  id="teklif-ad-soyad"
                  name="adSoyad"
                  required
                  class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white text-[#262322] placeholder-gray-400 dark:placeholder-gray-400 focus:border-[#E30A17] focus:outline-none focus:ring-1 focus:ring-[#E30A17]"
                  placeholder="Adınız Soyadınız"
                />
              </div>
              <div>
                <label for="teklif-telefon" class="block text-[#262322] dark:text-gray-200 text-sm font-medium mb-1.5">İletişim Telefonu</label>
                <input
                  type="tel"
                  id="teklif-telefon"
                  name="telefon"
                  required
                  class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white text-[#262322] placeholder-gray-400 focus:border-[#E30A17] focus:outline-none focus:ring-1 focus:ring-[#E30A17]"
                  placeholder="05XX XXX XX XX"
                />
              </div>
            </div>

            <div>
              <label for="teklif-email" class="block text-[#262322] dark:text-gray-200 text-sm font-medium mb-1.5">E-posta</label>
              <input
                type="email"
                id="teklif-email"
                name="email"
                required
                class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white text-[#262322] placeholder-gray-400 focus:border-[#E30A17] focus:outline-none focus:ring-1 focus:ring-[#E30A17]"
                placeholder="ornek@email.com"
              />
            </div>

            <div>
              <label for="teklif-apartman-adi" class="block text-[#262322] dark:text-gray-200 text-sm font-medium mb-1.5">Apartman Adı</label>
              <input
                type="text"
                id="teklif-apartman-adi"
                name="apartmanAdi"
                required
                class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white text-[#262322] placeholder-gray-400 focus:border-[#E30A17] focus:outline-none focus:ring-1 focus:ring-[#E30A17]"
                placeholder="Apartman adı"
              />
            </div>

            <div>
              <label for="teklif-adres" class="block text-[#262322] dark:text-gray-200 text-sm font-medium mb-1.5">Adres</label>
              <input
                type="text"
                id="teklif-adres"
                name="adres"
                required
                class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white text-[#262322] placeholder-gray-400 focus:border-[#E30A17] focus:outline-none focus:ring-1 focus:ring-[#E30A17]"
                placeholder="Adres bilgisi"
              />
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-5">
              <div>
                <label for="teklif-daire-sayisi" class="block text-[#262322] dark:text-gray-200 text-sm font-medium mb-1.5">Daire Sayısı</label>
                <input
                  type="number"
                  id="teklif-daire-sayisi"
                  name="daireSayisi"
                  min="1"
                  required
                  class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white text-[#262322] placeholder-gray-400 focus:border-[#E30A17] focus:outline-none focus:ring-1 focus:ring-[#E30A17]"
                  placeholder="Örn: 12"
                />
              </div>
              <div>
                <label for="teklif-dukkan-sayisi" class="block text-[#262322] dark:text-gray-200 text-sm font-medium mb-1.5">Dükkan Sayısı</label>
                <input
                  type="number"
                  id="teklif-dukkan-sayisi"
                  name="dukkanSayisi"
                  min="0"
                  class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white text-[#262322] placeholder-gray-400 focus:border-[#E30A17] focus:outline-none focus:ring-1 focus:ring-[#E30A17]"
                  placeholder="Örn: 2"
                />
              </div>
            </div>

            <div>
              <label for="teklif-mesaj" class="block text-[#262322] dark:text-gray-200 text-sm font-medium mb-1.5">Mesajınız</label>
              <textarea
                id="teklif-mesaj"
                name="mesaj"
                rows="4"
                class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white text-[#262322] placeholder-gray-400 focus:border-[#E30A17] focus:outline-none focus:ring-1 focus:ring-[#E30A17] resize-y min-h-[100px]"
                placeholder="Mesajınızı yazınız..."
              ></textarea>
            </div>

            <div class="flex flex-col-reverse sm:flex-row gap-3 sm:gap-4 pt-2">
              <button
                type="submit"
                class="w-full sm:flex-1 px-6 py-3 rounded-lg bg-[#E30A17] text-white font-medium hover:bg-[#c00914] transition-colors"
              >
                Gönder
              </button>
              <button
                type="button"
                id="teklif-form-iptal"
                class="w-full sm:flex-1 px-6 py-3 rounded-lg bg-white dark:bg-gray-700 border-2 border-[#E30A17] text-[#E30A17] font-medium hover:bg-[#E30A17]/5 transition-colors"
              >
                İptal
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <a
      href={whatsappUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="fixed bottom-6 right-6 z-[90] w-14 h-14 rounded-full bg-[#25D366] flex items-center justify-center shadow-lg hover:bg-[#20bd5a] hover:scale-110 transition-all duration-200"
      aria-label="WhatsApp ile iletişime geç"
    >
      <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
    </a>
  </body>
</html>

<script define:vars={{ apiBase: BASE_API_URL }}>
  document.addEventListener("DOMContentLoaded", () => {
    const modal = document.getElementById("teklif-form-modal");
    const closeBtn = document.getElementById("teklif-form-close");
    const iptalBtn = document.getElementById("teklif-form-iptal");
    const form = document.getElementById("teklif-form");

    let currentRelatedServiceId = null;

    function openTeklifModal() {
      if (!modal) return;
      modal.classList.remove("hidden");
      modal.classList.add("flex");
      modal.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";
    }

    function closeTeklifModal() {
      if (!modal) return;
      modal.classList.add("hidden");
      modal.classList.remove("flex");
      modal.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
    }

    document.addEventListener("click", (e) => {
      const target = e.target;
      if (target) {
        const trigger = target.closest(".open-teklif-modal");
        if (trigger) {
          e.preventDefault();
          const relatedId = trigger.getAttribute("data-related-service-id");
          currentRelatedServiceId =
            relatedId && relatedId.trim() ? relatedId.trim() : null;
          openTeklifModal();
        }
      }
    });

    closeBtn?.addEventListener("click", closeTeklifModal);
    iptalBtn?.addEventListener("click", closeTeklifModal);
    modal?.addEventListener("click", (e) => {
      if (e.target === modal) closeTeklifModal();
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && modal && !modal.classList.contains("hidden")) closeTeklifModal();
    });
    form?.addEventListener("submit", (e) => {
      e.preventDefault();
      if (!form) return;

      const adSoyadInput = document.getElementById("teklif-ad-soyad");
      const telefonInput = document.getElementById("teklif-telefon");
      const emailInput = document.getElementById("teklif-email");
      const apartmanAdiInput = document.getElementById("teklif-apartman-adi");
      const adresInput = document.getElementById("teklif-adres");
      const daireSayisiInput = document.getElementById("teklif-daire-sayisi");
      const dukkanSayisiInput = document.getElementById("teklif-dukkan-sayisi");
      const mesajInput = document.getElementById("teklif-mesaj");

      const payload = {
        relatedServiceId: currentRelatedServiceId,
        nameSurname: adSoyadInput?.value?.trim() || "",
        phone: telefonInput?.value?.trim() || "",
        email: emailInput?.value?.trim() || "",
        apartmentName: apartmanAdiInput?.value?.trim() || "",
        address: adresInput?.value?.trim() || "",
        flatCount: daireSayisiInput?.value?.toString() || "",
        shopCount: dukkanSayisiInput?.value?.toString() || "",
        message: mesajInput?.value?.trim() || "",
      };

      fetch(`${apiBase}/ProposalRequest`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          Accept: "application/json",
        },
        body: JSON.stringify(payload),
      })
        .then((res) => {
          if (res.ok) {
            alert("Talebiniz başarıyla iletildi. En kısa sürede sizinle iletişime geçeceğiz.");
          } else {
            alert("Talebiniz gönderilirken bir hata oluştu. Lütfen daha sonra tekrar deneyin.");
          }
        })
        .catch((err) => {
          console.error("Teklif formu gönderilirken hata oluştu:", err);
          alert("Talebiniz gönderilemedi. Lütfen internet bağlantınızı kontrol edip tekrar deneyin.");
        })
        .finally(() => {
          closeTeklifModal();
          form.reset();
        });
    });
  });
</script>
