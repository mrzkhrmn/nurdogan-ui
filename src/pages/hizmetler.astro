---
import MainLayout from "../layouts/MainLayout.astro";
import Footer from "../components/Footer.astro";
import { allServicesList } from "../data/services";
import { HizmetlerWithData } from "../components/WebsiteTabFetcher.jsx";
import HizmetlerServicesClient from "../components/HizmetlerServicesClient.jsx";

const baseUrl = (import.meta.env.BASE_URL || "/").replace(/\/?$/, "/");
---

<MainLayout>
  <div class="w-full min-h-screen bg-white dark:bg-gray-900 transition-colors duration-200">
    <HizmetlerWithData client:load />

    <!-- Ne Sunuyoruz - kategorilere göre kartlar -->
    <HizmetlerServicesClient client:load baseUrl={baseUrl} />
  </div>

  <Footer />
</MainLayout>
