---
import MainLayout from "../../layouts/MainLayout.astro";
import Footer from "../../components/Footer.astro";
import ReferencesSection from "../../components/sections/ReferencesSection.astro";
import Image from "astro/components/Image.astro";
import { allServicesList, projeTeknikSlugs, hukukiSlugs, RELATED_SERVICES_LIMIT } from "../../data/services";
import type { AllServiceItem } from "../../data/services";
import { BASE_API_URL } from "../../api/constants";

const baseUrl = (import.meta.env.BASE_URL || "/").replace(/\/?$/, "/");

export function getStaticPaths() {
  return allServicesList.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service: raw } = Astro.props;
const service: AllServiceItem & { imageFull: string } = {
  ...raw,
  imageFull: `${baseUrl}${raw.image}`,
};

const allServicesWithImage = allServicesList.map((s) => ({ ...s, imageFull: `${baseUrl}${s.image}` }));
const serviceBySlug = Object.fromEntries(allServicesWithImage.map((s) => [s.slug, s]));

const sameCategorySlugs =
  projeTeknikSlugs.includes(raw.slug)
    ? projeTeknikSlugs.filter((slug) => slug !== raw.slug)
    : hukukiSlugs.includes(raw.slug)
      ? hukukiSlugs.filter((slug) => slug !== raw.slug)
      : [];
const relatedServices = sameCategorySlugs
  .slice(0, RELATED_SERVICES_LIMIT)
  .map((slug) => serviceBySlug[slug])
  .filter(Boolean);

const whatsappNumber = import.meta.env.PUBLIC_WHATSAPP_PHONE || "905306544317";
const whatsappMessage = encodeURIComponent(
  `Merhaba, "${service.title}" hizmeti hakkında bilgi almak istiyorum.`
);
const whatsappUrl = `https://wa.me/${whatsappNumber}?text=${whatsappMessage}`;

interface ServiceDtoFromApi {
  id: string;
  title: string;
}

let relatedServiceId: string | null = null;

try {
  const res = await fetch(`${BASE_API_URL}/Website/get-services`, {
    headers: { Accept: "application/json" },
  });
  if (res.ok) {
    const categories = (await res.json()) as {
      services?: ServiceDtoFromApi[];
    }[];
    const all = categories.flatMap((c) => c.services ?? []);
    const matched = all.find((s) => s.title === service.title);
    relatedServiceId = matched?.id ?? null;
  }
} catch (_) {
  relatedServiceId = null;
}
---

<MainLayout>
  <div class="w-full min-h-screen bg-white dark:bg-gray-900 transition-colors duration-200">
    <section class="w-full pt-24 sm:pt-28 md:pt-42 pb-16 md:pb-24 px-4 md:px-6">
      <div class="max-w-[1200px] mx-auto">
        <a
          href={`${baseUrl}hizmetler`}
          class="inline-flex items-center gap-2 text-[#E30A17] text-sm md:text-base font-medium hover:underline mb-8 dark:hover:text-[#ff4d4d]"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Hizmetlere dön
        </a>

        <div class="flex flex-col lg:flex-row lg:gap-12 gap-10">
          <!-- Sol: Servis görseli -->
          <div class="flex-1 lg:max-w-md xl:max-w-lg shrink-0 order-1 lg:order-1">
            <div class="relative aspect-video lg:aspect-4/3 rounded-2xl overflow-hidden bg-gray-100 dark:bg-gray-800 shadow-lg">
              <Image
                src={service.imageFull}
                alt={service.title}
                width={560}
                height={420}
                class="w-full h-full object-cover"
              />
            </div>
          </div>

          <!-- Sağ: Başlık, açıklama, avantajlar, butonlar -->
          <div class="flex-1 min-w-0 order-2 lg:order-2">
            <h1 class="text-[#262322] dark:text-gray-100 text-2xl md:text-3xl lg:text-4xl font-bold leading-tight mb-5 md:mb-6">
              {service.title}
            </h1>
            <p class="text-[#525252] dark:text-gray-300 text-base md:text-lg leading-relaxed mb-8">
              {service.description}
            </p>

            <ul class="space-y-3 mb-8">
              {service.advantages.map((adv) => (
                <li class="flex items-start gap-3">
                  <span class="shrink-0 w-6 h-6 rounded-full bg-[#E30A17]/10 dark:bg-[#E30A17]/20 flex items-center justify-center mt-0.5">
                    <svg class="w-4 h-4 text-[#E30A17]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                  </span>
                  <span class="text-[#262322] dark:text-gray-200 text-sm md:text-base">{adv}</span>
                </li>
              ))}
            </ul>

            <div class="flex flex-wrap gap-4">
              <a
                href={whatsappUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center rounded-lg border-2 border-[#E30A17] px-6 py-3 text-base font-medium text-[#E30A17] hover:bg-[#E30A17]/5 dark:hover:bg-[#E30A17]/10 transition-colors"
              >
                Bilgi al
              </a>
              <button
                type="button"
                id="hizmet-detay-teklif-btn"
                class="open-teklif-modal inline-flex items-center justify-center rounded-lg bg-[#E30A17] px-6 py-3 text-base font-medium text-white hover:bg-[#c00914] transition-colors"
                data-related-service-id={relatedServiceId}
              >
                Teklif talep et
              </button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- İlgili Hizmetler (aynı kategoriden) -->
    {relatedServices.length > 0 && (
      <section class="w-full py-16 md:py-20 px-4 md:px-6 bg-gray-50 dark:bg-gray-800/50 border-t border-gray-100 dark:border-gray-700 transition-colors duration-200">
        <div class="max-w-[1200px] mx-auto">
          <h2 class="text-[#262322] dark:text-gray-100 text-xl md:text-2xl font-bold leading-tight mb-8">
            Bu kategorideki diğer hizmetler
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
            {relatedServices.map((item) => (
              <a
                href={`${baseUrl}hizmetler/${item.slug}`}
                class="group bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden shadow-sm hover:shadow-lg transition-all duration-300 flex flex-col"
              >
                <div class="relative aspect-video overflow-hidden bg-gray-100 dark:bg-gray-700">
                  <Image
                    src={item.imageFull}
                    alt={item.title}
                    width={400}
                    height={225}
                    class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                  />
                </div>
                <div class="p-4 md:p-5 flex flex-col flex-1">
                  <h3 class="text-[#262322] dark:text-gray-100 text-base md:text-lg font-semibold leading-snug group-hover:text-[#E30A17] transition-colors">
                    {item.title}
                  </h3>
                  <span class="mt-3 inline-flex items-center gap-1.5 text-[#E30A17] text-sm font-medium">
                    Detay
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                  </span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Referanslarımız -->
    <ReferencesSection />
  </div>

  <Footer />
</MainLayout>
