---
import { BASE_API_URL } from "../../api/constants";

interface BlockManagementDto {
  id: string;
  title: string;
  listOrder: number;
  logo: string;
  optionsJson: string;
}

type ServiceCard = {
  title: string;
  logo: string;
  items: string[];
};

function parseOptionsJson(raw: string | null | undefined): string[] {
  if (!raw) return [];
  try {
    const parsed = JSON.parse(raw);
    if (Array.isArray(parsed)) {
      return parsed.map((item) => String(item));
    }
    return [String(parsed)];
  } catch {
    return [raw];
  }
}

let serviceCards: ServiceCard[] = [];

try {
  const response = await fetch(`${BASE_API_URL}/Website/get-block-managements`);

  if (response.ok) {
    const data = (await response.json()) as BlockManagementDto[];

    serviceCards = data
      .slice()
      .sort(
        (a, b) =>
          (a.listOrder ?? 0) - (b.listOrder ?? 0),
      )
      .map((item) => ({
        title: item.title,
        logo: item.logo,
        items: parseOptionsJson(item.optionsJson),
      }));
  } else {
    console.error("Failed to fetch block management services", response.status);
  }
} catch (error) {
  console.error("Error while fetching block management services", error);
}
---

<section class="w-full bg-white dark:bg-gray-900 py-16 md:py-24 px-4 md:px-6 transition-colors duration-200">
  <div class="max-w-[1200px] mx-auto">
    <div class="text-center mb-12 md:mb-16">
      <p class="inline-block text-[#E30A17] text-sm sm:text-base md:text-lg font-bold tracking-wider uppercase mb-3 bg-[#E30A17]/15 dark:bg-[#E30A17]/25 px-4 py-2 sm:px-5 sm:py-2.5 rounded-xl">
        APARTMAN VE SİTE YÖNETİMİ
      </p>
      <h2 class="text-[#262322] dark:text-gray-100 text-2xl sm:text-3xl md:text-4xl lg:text-[42px] font-bold leading-tight">
        Bina Yönetimi Hizmetiyle Neler Sunuyoruz?
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8 mb-14 md:mb-16">
      {serviceCards.map((card) => (
        <div class="group/card bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 shadow-sm p-6 md:p-8 flex flex-col transition-colors duration-300 hover:bg-[#E30A17] hover:border-[#E30A17] dark:hover:bg-[#E30A17] dark:hover:border-[#E30A17]">
          <div class="flex items-start gap-4 mb-4">
            <div
              class="w-14 h-14 md:w-16 md:h-16 rounded-full bg-gray-100 dark:bg-gray-700 flex items-center justify-center shrink-0 transition-colors duration-300 group-hover/card:bg-white/20 [&>svg]:w-8 [&>svg]:h-8 [&>svg]:text-[#E30A17] group-hover/card:[&>svg]:text-white"
              aria-hidden
              set:html={card.logo}
            />
            <h3 class="text-[#262322] dark:text-gray-100 text-lg md:text-xl font-bold leading-snug pt-1 transition-colors duration-300 group-hover/card:text-white">
              {card.title}
            </h3>
          </div>
          <ul class="space-y-2 text-[#585858] dark:text-gray-300 text-sm md:text-base leading-relaxed list-disc list-inside transition-colors duration-300 group-hover/card:text-white">
            {card.items.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>

  </div>
</section>
