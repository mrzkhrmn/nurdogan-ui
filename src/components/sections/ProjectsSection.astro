---
import Image from "astro/components/Image.astro";
import { ArrowRightIcon } from "../icons";
import ProjectCard from "../ProjectCard.astro";
import { BASE_API_URL } from "../../api/constants";
import { getImageUrl } from "../../api";
import {
  completedProjects as staticCompletedProjects,
  ongoingProjects as staticOngoingProjects,
} from "../../data/projects";

const baseUrl = (import.meta.env.BASE_URL || "/").replace(/\/?$/, "/");
const projectsPageUrl = `${baseUrl}projeler`;

type ApiProject = {
  id: string;
  name: string;
  description: string;
  imageUrl: string;
  shortAddress: string;
  isFinished: boolean;
};

type UiProject = {
  id: string;
  name: string;
  description: string;
  image: string;
  location: string;
};

let apiProjects: ApiProject[] = [];

try {
  const response = await fetch(`${BASE_API_URL}/Website/get-projects`, {
    headers: { Accept: "application/json" },
  });

  if (response.ok) {
    apiProjects = await response.json();
  }
} catch (error) {
  console.error("Projeler alınırken bir hata oluştu:", error);
}

const mapStaticToUi = (p: { slug: string; name: string; description: string; image: string; location: string }): UiProject => ({
  id: p.slug,
  name: p.name,
  description: p.description,
  image: `${baseUrl}${p.image}`,
  location: p.location,
});

let completedProjects: UiProject[];
let ongoingProjects: UiProject[];

if (apiProjects.length > 0) {
  const mapApiToUi = (p: ApiProject): UiProject => {
    const imageUrl = getImageUrl(p.imageUrl);
    return {
      id: p.id,
      name: p.name,
      description: p.description,
      image: imageUrl || `${baseUrl}construction1.png`,
      location: p.shortAddress,
    };
  };

  completedProjects = apiProjects.filter((p) => p.isFinished).map(mapApiToUi);
  ongoingProjects = apiProjects.filter((p) => !p.isFinished).map(mapApiToUi);
} else {
  completedProjects = staticCompletedProjects.map(mapStaticToUi);
  ongoingProjects = staticOngoingProjects.map(mapStaticToUi);
}
---

<section id="projeler" class="w-full bg-gray-100 dark:bg-gray-900 py-4 pb-12 md:py-20 px-4 md:px-6 transition-colors duration-200">
  <div class="max-w-[1480px] mx-auto">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-6 md:mb-10 gap-4 md:gap-0">
      <div>
        <p class="inline-block text-[#E30A17] text-sm sm:text-base md:text-4xl font-bold mb-4 tracking-wider uppercase bg-[#E30A17]/15 px-4 py-2 sm:px-5 sm:py-2.5 rounded-xl">
          342+ TAMAMLANAN PROJE
        </p>
        <h2 class="text-[#262322] dark:text-gray-100 text-2xl md:text-5xl font-semibold leading-tight">
          Projeler
        </h2>
      </div>
      
      <a
      href={projectsPageUrl}
      class="ml-auto inline-flex justify-end items-center gap-2 sm:gap-3 rounded-full bg-[#E30A17] pl-1.5 sm:pl-2 pr-4 sm:pr-6 py-1.5 sm:py-2 text-sm sm:text-base font-medium text-white hover:bg-[#e30a18df] transition-all duration-300 shadow-lg hover:shadow-xl"
    >
      <div class="w-7 h-7 sm:w-8 sm:h-8 rounded-full bg-white flex items-center justify-center shrink-0">
        <ArrowRightIcon color="#E30A17"/>
      </div>
      Daha Fazla
    </a>
    </div>

    <!-- Sekmeler -->
    <div class="flex flex-wrap items-center gap-4 mb-8 md:mb-12 border-b border-gray-200 dark:border-gray-600">
      <button 
        class="project-tab px-4 py-2 md:px-6 md:py-3 text-sm md:text-base font-semibold border-b-2 border-transparent text-[#262322] dark:text-gray-200 transition-colors active-tab"
        data-tab="completed"
        id="tab-completed"
      >
        Tamamlanan Projelerimiz
      </button>
      <button 
        class="project-tab px-4 py-2 md:px-6 md:py-3 text-sm md:text-base font-semibold border-b-2 border-transparent text-[#262322] dark:text-gray-200 transition-colors"
        data-tab="ongoing"
        id="tab-ongoing"
      >
        Devam Eden Projelerimiz
      </button>
    </div>

    <div class="relative">
      <!-- Tamamlanan Projeler -->
      <div class="projects-panel" id="panel-completed">
        <!-- Tüm ekranlar: yatay kaydırma -->
        <div class="projects-scroll flex gap-4 overflow-x-auto overflow-y-hidden scroll-smooth snap-x snap-mandatory py-2 pb-4">
          {completedProjects.map((project) => (
            <ProjectCard
              href={`${baseUrl}projeler/${project.id}`}
              image={project.image}
              name={project.name}
              location={project.location}
              class="shrink-0 w-[260px] sm:w-[320px] md:w-[360px] lg:w-[380px] xl:w-[400px] snap-start"
            />
          ))}
        </div>
      </div>

      <!-- Devam Eden Projeler (isFinished: false) -->
      <div class="projects-panel hidden" id="panel-ongoing">
        <!-- Tüm ekranlar: yatay kaydırma -->
        <div class="projects-scroll flex gap-4 overflow-x-auto overflow-y-hidden scroll-smooth snap-x snap-mandatory py-2 pb-4">
          {ongoingProjects.map((project) => (
            <ProjectCard
              href={`${baseUrl}projeler/${project.id}`}
              image={project.image}
              name={project.name}
              location={project.location}
              class="shrink-0 w-[260px] sm:w-[320px] md:w-[360px] lg:w-[380px] xl:w-[400px] snap-start"
            />
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .projects-scroll {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .projects-scroll::-webkit-scrollbar {
    display: none;
  }

  .project-tab {
    cursor: pointer;
  }

  .project-tab:not(.active-tab) {
    color: #262322;
  }

  :global(.dark) .project-tab:not(.active-tab) {
    color: #e5e7eb;
  }

  .project-tab:hover {
    color: #E30A17;
  }

  .project-tab.active-tab {
    color: #E30A17;
    border-bottom-color: #E30A17;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const tabs = document.querySelectorAll("#projeler .project-tab");
    const panelCompleted = document.getElementById("panel-completed");
    const panelOngoing = document.getElementById("panel-ongoing");

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const tabType = tab.getAttribute("data-tab");
        if (!tabType) return;

        tabs.forEach((t) => {
          t.classList.remove("active-tab", "border-[#E30A17]", "text-[#E30A17]");
          t.classList.add("border-transparent");
        });
        tab.classList.add("active-tab", "border-[#E30A17]", "text-[#E30A17]");
        tab.classList.remove("border-transparent");

        if (tabType === "ongoing") {
          panelCompleted?.classList.add("hidden");
          panelOngoing?.classList.remove("hidden");
        } else {
          panelCompleted?.classList.remove("hidden");
          panelOngoing?.classList.add("hidden");
        }
      });
    });
  });
</script>

